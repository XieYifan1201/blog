---
export interface Props {
    title?: string;
    description?: string;
    image?: string;
}

const {
    title = 'OneSail Tech',
    description = 'OneSail Tech — 分享技术、设计与生活随笔',
    image = '/favicon.webp',
} = Astro.props;

---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/webp" href="/favicon.webp" />

		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="generator" content="1Fan" />

		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:locale" content="zh_CN" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
	</head>
	<body>
		<slot />
		<footer class="site-footer">
			<p>© {new Date().getFullYear()} OneSail Tech. All rights reserved.</p>
		</footer>
		<div class="bg-waves">
			<img src="/background.svg" alt="" class="bg-wave-img" />
		</div>
	</body>
</html>

<style is:global>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		background-color: #0a0a0a;
		font-family: sans-serif;
	}

	body {
		position: relative;
	}

	.bg-waves {
		position: fixed;
		bottom: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		pointer-events: none;
		overflow: hidden;
	}

	.bg-wave-img {
		position: absolute;
		bottom: 0;
		left: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.5;
	}

	.site-footer {
		text-align: center;
		padding: 2rem 1rem;
		z-index: 10;
	}

	.site-footer p {
		color: rgba(255, 255, 255, 0.3);
		font-size: 0.75rem;
		margin: 0;
	}
</style>
