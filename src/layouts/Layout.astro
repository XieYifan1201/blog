---
export interface Props {
    title?: string;
    description?: string;
    image?: string;
}

const {
    title = 'XIE YIFAN',
    description = 'XIE YIFAN — 分享技术、设计与生活随笔',
    image = '/favicon.webp',
} = Astro.props;

---

<!doctype html>
<html lang="zh-CN">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/webp" href="/favicon.webp" />

        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="generator" content="1Fan" />

        <meta property="og:type" content="website" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:locale" content="zh_CN" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
    </head>
    <body>
        <slot />
        <footer class="site-footer">
            <p>© {new Date().getFullYear()} XIE YIFAN. All rights reserved.</p>
            <!-- <p><a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener">赣ICP备XXXXXXXX号</a></p> -->
        </footer>
    </body>
</html>

<style is:global>
    :root {
        --site-content-width: 1100px;
        --site-narrow-width: 900px;
        --site-page-gutter-total: 2.5rem;
        --shadow-card: 0 10px 30px rgba(15, 23, 42, 0.06);
        --shadow-card-hover: 0 16px 36px rgba(37, 99, 235, 0.13);
        --shadow-button: 0 8px 18px rgba(37, 99, 235, 0.18);
        --shadow-button-hover: 0 12px 24px rgba(37, 99, 235, 0.25);
        --shadow-button-neutral: 0 6px 16px rgba(15, 23, 42, 0.07);
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        outline: none;
    }

    html {
        overflow-x: hidden;
        scrollbar-gutter: stable;
    }

    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #ccc; border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: #999; }
    * { scrollbar-width: thin; scrollbar-color: #ccc transparent; }

    html,
    body {
        width: 100%;
        min-height: 100%;
        background-color: #ffffff;
        color: #000000;
        font-family: sans-serif;
    }

    .site-footer {
        text-align: center;
        padding: 2rem 1rem;
        z-index: 10;
    }

    .site-footer p {
        color: #999;
        font-size: 0.75rem;
        margin: 0;
    }

    .site-footer a {
        color: #999;
        text-decoration: none;
        transition: color 0.2s;
    }

    .site-footer a:hover {
        color: #2563eb;
    }
</style>
