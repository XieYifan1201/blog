---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="文章 - XIE YIFAN" description="XIE YIFAN 的技术文章与随笔">
    <Nav active="文章" />

    <main>
        <section id="posts-hero">
            <h1>全部文章</h1>
            <p class="subtitle">记录技术探索与思考的过程</p>
        </section>

        {posts.length > 0 ? (
        <div class="posts-grid">
            {posts.map((post) => (
                <a href={`/posts/${post.id}`} class="post-card">
                    <div class="post-meta">
                        <time>{post.data.date.toLocaleDateString('zh-CN')}</time>
                        {post.data.tags.map((tag) => (
                            <span class="tag">{tag}</span>
                        ))}
                    </div>
                    <h3>{post.data.title}</h3>
                    <p>{post.data.description}</p>
                    <span class="read-more">阅读全文 →</span>
                </a>
            ))}
        </div>
        ) : (
        <div class="empty">
            <p>暂无文章，敬请期待。</p>
        </div>
        )}
    </main>
</Layout>

<style>
    main {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2rem 0 4rem;
        max-width: var(--site-content-width);
        margin: 0 auto;
        width: calc(100% - var(--site-page-gutter-total));
    }

    #posts-hero {
        text-align: center;
        margin-bottom: 3rem;
        animation: fadeInUp 0.8s ease-out;
    }

    h1 {
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 900;
        letter-spacing: -2px;
        line-height: 1.1;
        margin-bottom: 0.8rem;
        color: #000;
    }

    .subtitle {
        font-size: 1.1rem;
        color: #666;
    }

    .posts-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        width: 100%;
        animation: fadeInUp 0.8s ease-out 0.15s both;
    }

    .post-card {
        background: #fff;
        border: 1px solid #eee;
        border-radius: 16px;
        padding: 1.8rem;
        text-decoration: none;
        color: inherit;
        transition: all 0.3s;
        display: flex;
        flex-direction: column;
        box-shadow: var(--shadow-card);
    }

    .post-card:hover {
        border-color: #2563eb;
        transform: translateY(-4px);
        box-shadow: var(--shadow-card-hover);
    }

    .post-meta {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 0.8rem;
        flex-wrap: wrap;
    }

    .post-meta time {
        font-size: 0.8rem;
        color: #999;
    }

    .tag {
        background: #f0f4ff;
        border: 1px solid #dbeafe;
        color: #2563eb;
        padding: 2px 10px;
        border-radius: 20px;
        font-size: 0.7rem;
    }

    .post-card h3 {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        line-height: 1.4;
        color: #000;
    }

    .post-card p {
        font-size: 0.85rem;
        color: #666;
        line-height: 1.6;
        margin-bottom: 1rem;
        flex: 1;
    }

    .read-more {
        font-size: 0.85rem;
        color: #2563eb;
        font-weight: 600;
    }

    .empty {
        text-align: center;
        animation: fadeInUp 0.8s ease-out;
    }

    .empty p {
        color: #666;
        font-size: 1.1rem;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 900px) {
        main { padding: 2rem 0 4rem; }
        h1 { font-size: 2rem; }
        .posts-grid { grid-template-columns: 1fr; }
    }
</style>
