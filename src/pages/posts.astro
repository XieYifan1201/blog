---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout>
<div id="container">
    <div class="spotlight"></div>

    <nav>
        <a href="/" class="logo"><img src="/favicon.jpeg" alt="Logo" class="logo-img" /></a>
        <div class="nav-links">
            <a href="/">首页</a>
            <a href="/posts" class="active">文章</a>
            <a href="/about">关于</a>
        </div>
    </nav>

    <main>
        <section id="posts-hero">
            <h1>全部<span class="gradient-text">文章</span></h1>
            <p class="subtitle">记录技术探索与思考的过程</p>
        </section>

        {posts.length > 0 ? (
        <div class="posts-grid">
            {posts.map((post) => (
                <a href={`/posts/${post.id}`} class="post-card">
                    <div class="post-meta">
                        <time>{post.data.date.toLocaleDateString('zh-CN')}</time>
                        {post.data.tags.map((tag) => (
                            <span class="tag">{tag}</span>
                        ))}
                    </div>
                    <h3>{post.data.title}</h3>
                    <p>{post.data.description}</p>
                    <span class="read-more">阅读全文 →</span>
                </a>
            ))}
        </div>
        ) : (
        <div class="empty">
            <p>暂无文章，敬请期待。</p>
            <a href="/" class="button primary">返回首页</a>
        </div>
        )}

        <footer class="page-footer">
            <a href="/" class="button primary">返回首页</a>
        </footer>
    </main>
</div>
</Layout>

<style>
    :root {
        --accent: #7c3aed;
        --accent-gradient: linear-gradient(45deg, #7c3aed, #ff1fb1);
        --bg-color: #0a0a0a;
        --text-main: #ffffff;
        --text-muted: #a1a1aa;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background-color: var(--bg-color);
        color: var(--text-main);
        font-family: 'Inter', 'SF Pro Display', system-ui, sans-serif;
        overflow-x: hidden;
    }

    #container {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        position: relative;
    }

    .spotlight {
        position: fixed;
        top: -20%;
        left: 50%;
        transform: translateX(-50%);
        width: 80vw;
        height: 60vh;
        background: radial-gradient(circle, rgba(124, 58, 237, 0.15) 0%, rgba(0,0,0,0) 70%);
        z-index: -1;
        pointer-events: none;
    }

    nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 2rem 10%;
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(10, 10, 10, 0.8);
        backdrop-filter: blur(12px);
    }

    .logo {
        text-decoration: none;
        display: flex;
        align-items: center;
    }

    .logo-img {
        height: 36px;
        width: 36px;
        object-fit: cover;
        border-radius: 50%;
    }

    .nav-links a {
        color: var(--text-muted);
        text-decoration: none;
        margin-left: 2rem;
        font-size: 0.9rem;
        transition: color 0.3s;
    }

    .nav-links a:hover,
    .nav-links a.active {
        color: var(--text-main);
    }

    main {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2rem 1rem 4rem;
    }

    #posts-hero {
        text-align: center;
        max-width: 700px;
        animation: fadeInUp 0.8s ease-out;
        margin-bottom: 3rem;
    }

    h1 {
        font-size: clamp(2.5rem, 8vw, 4.5rem);
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 1rem;
    }

    .gradient-text {
        background: var(--accent-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .subtitle {
        font-size: 1.15rem;
        color: var(--text-muted);
    }

    .posts-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        max-width: 900px;
        width: 100%;
        animation: fadeInUp 0.8s ease-out 0.15s both;
    }

    .post-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        padding: 1.8rem;
        text-decoration: none;
        color: inherit;
        transition: all 0.3s;
        backdrop-filter: blur(10px);
        display: flex;
        flex-direction: column;
    }

    .post-card:hover {
        border-color: var(--accent);
        background: rgba(255, 255, 255, 0.05);
        transform: translateY(-4px);
    }

    .post-meta {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 0.8rem;
        flex-wrap: wrap;
    }

    .post-meta time {
        font-size: 0.8rem;
        color: var(--text-muted);
    }

    .tag {
        background: rgba(124, 58, 237, 0.1);
        border: 1px solid rgba(124, 58, 237, 0.3);
        color: #a78bfa;
        padding: 2px 10px;
        border-radius: 20px;
        font-size: 0.7rem;
    }

    .post-card h3 {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        line-height: 1.4;
    }

    .post-card p {
        font-size: 0.85rem;
        color: var(--text-muted);
        line-height: 1.5;
        margin-bottom: 1rem;
        flex: 1;
    }

    .read-more {
        font-size: 0.85rem;
        color: var(--accent);
        font-weight: 600;
        transition: color 0.3s;
    }

    .post-card:hover .read-more {
        color: #a78bfa;
    }

    .empty {
        text-align: center;
        animation: fadeInUp 0.8s ease-out;
    }

    .empty p {
        color: var(--text-muted);
        font-size: 1.1rem;
        margin-bottom: 2rem;
    }

    .button {
        padding: 0.8rem 2rem;
        border-radius: 12px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s;
    }

    .button.primary {
        background: var(--text-main);
        color: var(--bg-color);
    }

    .button.primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(255, 255, 255, 0.1);
    }

    .page-footer {
        margin-top: 3rem;
        text-align: center;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 768px) {
        nav { padding: 1.5rem 5%; }
        h1 { font-size: 2.5rem; }
        .posts-grid { grid-template-columns: 1fr; }
    }
</style>
