---
const name = "谢怡帆";
const email = "onesailtech@gmail.com";
const avatar = "/favicon.jpeg";

const techStack = [
    "Vue.js",
    "Flutter",
    "TypeScript",
    "Node.js",
    "Astro",
    "UI/UX Design",
];

const awards = [
    { title: "入围第48届世界技能大赛移动应用开发中国集训队", certIndex: -1 },
    { title: "第48届世界技能大赛中国集训队集中性考核暨测试赛移动应用开发赛项 第六名", certIndex: -1 },
    { title: "中华人民共和国第三届职业技能大赛移动应用开发赛项 第六名", certIndex: 2 },
    { title: "2024至2025学年国家奖学金", certIndex: 0 },
    { title: "计算机程序设计员职业技能等级 高级技师", certIndex: -1 },
    { title: "2023至2024学年国家励志奖学金", certIndex: 1 },
    { title: "一带一路暨金砖国家技能发展与技术创新大赛——Web赛项 三等奖", certIndex: 3 },
    { title: "江西省第二届职业技能大赛移动应用开发赛项 第一名", certIndex: 4 },
    { title: "江西省第一届职业技能大赛网站设计与开发赛项 第二名", certIndex: 5 },
    { title: "九江市第三届职业技能大赛移动应用开发赛项 第一名", certIndex: 6 },
];

const education = [
    { school: "江西省电子信息工程学校", major: "计算机网络技术（中专）", period: "2020 - 2023" },
    { school: "江西职业技术大学", major: "移动互联应用技术（大专）", period: "2023 - 2026" },
    // { school: "江西工程学院", major: "计算机科学与技术（本科）", period: "2026 - 2028" },
];

const allCerts = [
    "/certificates/gjjxj.jpeg",
    "/certificates/gjlzjxj.jpeg",
    "/certificates/zhrmghgdsjzyjnds.jpeg",
    "/certificates/ydyljjzgjjnfzyjscxds.jpeg",
    "/certificates/jxsdejzyjnds.jpeg",
    "/certificates/jxsdyjzyjnds.jpeg",
    "/certificates/jjsdsjchjjzyjnds.jpeg",
    "/certificates/jxzyjsdxdwjcxsjds.jpeg",
    "/certificates/jxzyjsdxydjxj1.jpeg",
    "/certificates/jxzyjsdxydjxj2.jpeg",
];
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>关于 - OneSail Tech</title>
    <meta name="description" content="关于 OneSail Tech — 个人介绍、荣誉与证书">
    <link rel="icon" type="image/jpeg" href="/favicon.jpeg" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/viewerjs/1.11.3/viewer.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            outline: none;
        }

        html {
            overflow-x: hidden;
            scrollbar-gutter: stable;
        }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #ccc; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #999; }
        * { scrollbar-width: thin; scrollbar-color: #ccc transparent; }

        body {
            background-color: #ffffff;
            color: #000000;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        }

        /* ===== Nav ===== */
        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.5rem 8vw;
            position: relative;
            z-index: 10;
        }

        .logo {
            text-decoration: none;
            display: flex;
            align-items: center;
        }

        .logo-img {
            height: 32px;
            width: 32px;
            object-fit: cover;
            border-radius: 50%;
        }

        .nav-links {
            display: flex;
            gap: 1.8rem;
        }

        .nav-links a {
            color: #666;
            text-decoration: none;
            font-size: 0.9rem;
            transition: color 0.3s;
            font-weight: 500;
        }

        .nav-links a:hover,
        .nav-links a.active {
            color: #2563eb;
        }

        /* ===== Layout ===== */
        .layout {
            display: flex;
            width: 100%;
            min-height: calc(100vh - 80px);
        }

        .left-panel {
            flex: 0 0 60%;
            padding: 6vh 3vw 6vh 8vw;
            display: flex;
            flex-direction: column;
            gap: 4vh;
        }

        .header .name {
            font-size: clamp(3rem, 5vw, 5rem);
            font-weight: 900;
            letter-spacing: -2px;
            margin-bottom: 0.5vh;
        }

        .header .email {
            font-size: 1.1rem;
            color: #666;
            text-decoration: none;
            transition: color 0.2s;
        }

        .header .email:hover {
            color: #2563eb;
        }

        .section-title {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #999;
            margin-bottom: 1.5vh;
            font-weight: 600;
            border-bottom: 1px solid #eee;
            padding-bottom: 0.5vh;
            border-left: 3px solid #2563eb;
            padding-left: 10px;
        }

        .tech-stack {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .tech-stack span {
            font-size: 0.9rem;
            padding: 6px 16px;
            border: 1px solid #ddd;
            border-radius: 50px;
            color: #333;
        }

        .awards-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.5vh 2vw;
            list-style: none;
        }

        .award-item {
            font-size: 0.95rem;
            color: #333;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid transparent;
            padding-bottom: 2px;
            transition: all 0.2s;
            line-height: 1.4;
        }

        .award-item.has-cert {
            cursor: pointer;
        }

        .award-item.has-cert:hover {
            color: #2563eb;
            border-bottom-color: #2563eb;
        }

        .award-item.has-cert::after {
            content: '↗';
            color: #ccc;
            font-size: 0.8rem;
            margin-left: 8px;
            flex-shrink: 0;
        }

        .edu-list {
            display: flex;
            flex-direction: column;
            gap: 1.5vh;
        }

        .edu-item {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            border-left: 4px solid #2563eb;
            padding-left: 12px;
        }

        .edu-school {
            font-weight: bold;
            font-size: 1.05rem;
        }

        .edu-major {
            font-size: 0.9rem;
            color: #666;
            margin-top: 2px;
        }

        .edu-time {
            font-size: 0.9rem;
            color: #999;
        }

        .right-panel {
            flex: 0 0 40%;
            height: calc(100vh - 80px);
            position: sticky;
            top: 80px;
            display: flex;
            align-items: flex-end;
            justify-content: flex-end;
        }

        .portrait {
            width: auto;
            height: 90vh;
            max-width: 100%;
            object-fit: contain;
            object-position: bottom;
        }

        #gallery {
            display: none;
        }

        /* ===== Animations ===== */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .layout {
            animation: fadeIn 0.8s ease-out;
        }

        .left-panel > * {
            opacity: 0;
            animation: fadeInUp 0.6s ease-out forwards;
        }

        .left-panel > *:nth-child(1) { animation-delay: 0.1s; }
        .left-panel > *:nth-child(2) { animation-delay: 0.2s; }
        .left-panel > *:nth-child(3) { animation-delay: 0.3s; }
        .left-panel > *:nth-child(4) { animation-delay: 0.4s; }
        .left-panel > *:nth-child(5) { animation-delay: 0.5s; }

        .right-panel {
            opacity: 0;
            animation: fadeInUp 0.6s ease-out 0.3s forwards;
        }

        /* ===== Hover effects ===== */
        .tech-stack span {
            transition: transform 0.2s, background 0.2s, color 0.2s, border-color 0.2s;
            cursor: default;
        }

        .tech-stack span:hover {
            transform: translateY(-3px);
            background: #2563eb;
            color: #fff;
            border-color: #2563eb;
        }

        .award-item.has-cert {
            transition: transform 0.2s, border-color 0.2s, color 0.2s;
        }

        .award-item.has-cert:hover {
            transform: translateX(3px);
        }

        .edu-item {
            transition: transform 0.2s;
        }

        .edu-item:hover {
            transform: translateX(5px);
        }

        .portrait {
            transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .portrait:hover {
            transform: scale(1.02);
        }

        @media (max-width: 900px) {
            nav {
                padding: 1rem 5vw;
            }
            .nav-links {
                gap: 1rem;
            }
            .nav-links a {
                font-size: 0.8rem;
            }
            .layout {
                flex-direction: column-reverse;
                display: flex;
            }
            .left-panel {
                flex: none;
                width: 100%;
                padding: 4vh 6vw 10vh 6vw;
            }
            .header {
                text-align: center;
            }
            .right-panel {
                flex: none;
                width: 100%;
                height: 60vh;
                position: relative;
                top: 0;
                justify-content: center;
            }
            .portrait {
                height: 100%;
            }
            .awards-grid {
                grid-template-columns: 1fr;
            }
            .edu-item {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
</head>
<body>

    <nav>
        <a href="/" class="logo"><img src="/favicon.jpeg" alt="Logo" class="logo-img" /></a>
        <div class="nav-links">
            <a href="/">首页</a>
            <a href="/posts">文章</a>
            <a href="/projects">项目</a>
            <a href="/tools">工具</a>
            <a href="/about" class="active">关于</a>
        </div>
    </nav>

    <div class="layout">
        <section class="left-panel">
            <div class="header">
                <h1 class="name">{name}</h1>
                <a class="email" href={`mailto:${email}`}>{email}</a>
            </div>

            <div>
                <div class="section-title">技术栈 / Technical Stack</div>
                <div class="tech-stack">
                    {techStack.map(s => <span>{s}</span>)}
                </div>
            </div>

            <div>
                <div class="section-title">获奖列表 / Awards</div>
                <ul class="awards-grid">
                    {awards.map((award) => (
                        <li class={`award-item${award.certIndex >= 0 ? ' has-cert' : ''}`} data-cert-index={award.certIndex}>
                            {award.title}
                        </li>
                    ))}
                </ul>
            </div>

            <div>
                <div class="section-title">教育背景 / Education</div>
                <div class="edu-list">
                    {education.map(e => (
                        <div class="edu-item">
                            <div>
                                <div class="edu-school">{e.school}</div>
                                <div class="edu-major">{e.major}</div>
                            </div>
                            <div class="edu-time">{e.period}</div>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <section class="right-panel">
            <img src={avatar} alt="Profile" class="portrait" />
        </section>
    </div>

    <div id="gallery">
        {allCerts.map(src => <img src={src} alt="" />)}
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/viewerjs/1.11.3/viewer.min.js">
    </script>
    <script>
        const galleryElement = document.getElementById('gallery');

        const viewer = new Viewer(galleryElement, {
            url: 'src',
            toolbar: true,
            navbar: false,
            zoomable: true,
            scalable: true,
            rotatable: true,
            movable: true,
            transition: true,
            fullscreen: true,
            shown() { document.documentElement.style.overflow = 'hidden'; },
            hidden() { document.documentElement.style.overflow = ''; },
        });

        document.querySelectorAll('.award-item.has-cert').forEach(item => {
            item.addEventListener('click', function () {
                const index = parseInt(this.getAttribute('data-cert-index'));
                if (!isNaN(index) && index >= 0) {
                    viewer.view(index);
                }
            });
        });
    </script>
</body>
</html>