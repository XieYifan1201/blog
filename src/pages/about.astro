---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';

const name = "谢怡帆";
const email = "onesailtech@gmail.com";
const avatar = "/favicon.webp";

const techStack = [
    "Java",
    "Kotlin",
    "Jetpack Compose",
    "Flutter",
    "Spring Boot",
    "MySQL",
    "Node.js",
    "Vue",
    "Git",
    "Figma",
    "Photoshop",
];

const awards = [
    { title: "2024至2025学年国家奖学金", certIndex: 0 },
    { title: "2023至2024学年国家励志奖学金", certIndex: 1 },
    { title: "计算机程序设计员职业技能等级 高级技师", certIndex: 2 },
    { title: "计算机程序设计员职业技能等级 技师", certIndex: 3 },
    { title: "入围第48届世界技能大赛移动应用开发中国集训队", certIndex: -1 },
    { title: "中华人民共和国第三届职业技能大赛移动应用开发赛项 第六名", certIndex: 4 },
    { title: "一带一路暨金砖国家技能发展与技术创新大赛——Web赛项 三等奖", certIndex: 5 },
    { title: "江西省第二届职业技能大赛移动应用开发赛项 第一名", certIndex: 6 },
    { title: "江西省第一届职业技能大赛网站设计与开发赛项 第二名", certIndex: 7 },
    { title: "九江市第三届职业技能大赛移动应用开发赛项 第一名", certIndex: 8 },
    { title: "学校奖学金", certIndex: 9 },
    { title: "优秀毕业生", certIndex: 10 },
];

const education = [
    { school: "江西职业技术大学", major: "移动互联应用技术（大专）", period: "2023 - 2026" },
    { school: "江西省电子信息工程学校", major: "计算机网络技术（中专）", period: "2020 - 2023" },
];

const allCerts = [
    "/certificates/National_Scholarship.webp",
    "/certificates/National_Inspirational_Scholarship.webp",
    "/certificates/Senior_Technician.webp",
    "/certificates/technician.webp",
    "/certificates/The_3rd_China_Vocational_Skills_Competition.webp",
    "/certificates/Belt&Road_and_BRICS_Skills_Development_and_Technology_Innovation_Competition.webp",
    "/certificates/The_2nd_Vocational_Skills_Competition_of_Jiangxi_Province.webp",
    "/certificates/The_First_Vocational_Skills_Competition_of_Jiangxi_Province.webp",
    "/certificates/The_3rd_Vocational_Skills_Competition_of_Jiujiang_City.webp",
    "/certificates/school_scholarship.webp",
    "/certificates/Outstanding_Graduate.webp",
];
---

<Layout title="关于 - XIE YIFAN" description="关于 XIE YIFAN — 个人介绍、荣誉与证书">
    <link rel="stylesheet" href="/viewer.min.css">

    <Nav active="关于" />

    <div class="layout">
        <section class="left-panel">
            <div class="header">
                <h1 class="name">{name}</h1>
                <span class="email-wrapper">
                    <a class="email" href={`mailto:${email}`}>{email}</a>
                    <span class="copy-icon" data-email={email} title="复制邮箱">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                        </svg>
                    </span>
                </span>
            </div>

            <div>
                <div class="section-title">技术栈 / Technical Stack</div>
                <div class="tech-stack">
                    {techStack.map(s => <span>{s}</span>)}
                </div>
            </div>

            <div>
                <div class="section-title">获奖列表 / Awards</div>
                <ul class="awards-grid">
                    {awards.map((award) => (
                        <li class={`award-item${award.certIndex >= 0 ? ' has-cert' : ''}`} data-cert-index={award.certIndex}>
                            {award.title}
                        </li>
                    ))}
                </ul>
            </div>

            <div>
                <div class="section-title">教育背景 / Education</div>
                <div class="edu-list">
                    {education.map(e => (
                        <div class="edu-item">
                            <div>
                                <div class="edu-school">{e.school}</div>
                                <div class="edu-major">{e.major}</div>
                            </div>
                            <div class="edu-time">{e.period}</div>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <section class="right-panel">
            <img src={avatar} alt="Profile" class="portrait" />
        </section>
    </div>

    <div id="gallery">
        {allCerts.map(src => <img src={src} alt="" />)}
    </div>

    <script is:inline src="/viewer.min.js"></script>
    <script>
        const galleryElement = document.getElementById('gallery');

        const viewer = new Viewer(galleryElement, {
            url: 'src',
            toolbar: true,
            navbar: false,
            zoomable: true,
            scalable: true,
            rotatable: true,
            movable: true,
            transition: true,
            fullscreen: true,
        });

        document.addEventListener('click', function (e) {
            const container = document.querySelector('.viewer-container');
            if (container && container.style.display !== 'none' && (e.target === container || e.target === container.querySelector('.viewer-mask'))) {
                viewer.hide();
            }
        });

        document.querySelectorAll('.award-item.has-cert').forEach(item => {
            item.addEventListener('click', function () {
                const index = parseInt(this.getAttribute('data-cert-index'));
                if (!isNaN(index) && index >= 0) {
                    viewer.view(index);
                }
            });
        });

        document.querySelector('.copy-icon')?.addEventListener('click', function () {
            const email = this.getAttribute('data-email');
            navigator.clipboard.writeText(email).then(() => {
                const original = this.innerHTML;
                this.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
                this.classList.add('copied');
                setTimeout(() => {
                    this.innerHTML = original;
                    this.classList.remove('copied');
                }, 1500);
            });
        });
    </script>
</Layout>

<style>
    .layout {
        display: flex;
        width: 100%;
        min-height: calc(100vh - 80px);
    }

    .left-panel {
        flex: 0 0 60%;
        padding: 6vh 3vw 6vh 8vw;
        display: flex;
        flex-direction: column;
        gap: 4vh;
    }

    .header .name {
        font-size: clamp(3rem, 5vw, 5rem);
        font-weight: 900;
        letter-spacing: -2px;
        margin-bottom: 0.5vh;
    }

    .header .email {
        font-size: 1.1rem;
        color: #666;
        text-decoration: none;
        transition: color 0.2s;
    }

    .header .email:hover {
        color: #2563eb;
    }

    .header .email-wrapper {
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .header .copy-icon {
        display: inline-flex;
        align-items: center;
        cursor: pointer;
        color: #999;
        transition: color 0.2s;
        line-height: 1;
    }

    .header .copy-icon:hover {
        color: #2563eb;
    }

    .header .copy-icon.copied {
        color: #16a34a;
    }

    .section-title {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #999;
        margin-bottom: 1.5vh;
        font-weight: 600;
        border-bottom: 1px solid #eee;
        padding-bottom: 0.5vh;
        border-left: 3px solid #2563eb;
        padding-left: 10px;
    }

    .tech-stack {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .tech-stack span {
        font-size: 0.9rem;
        padding: 6px 16px;
        border: 1px solid #ddd;
        border-radius: 50px;
        color: #333;
        transition: transform 0.2s, background 0.2s, color 0.2s, border-color 0.2s;
        cursor: default;
        box-shadow: var(--shadow-button-neutral);
    }

    .tech-stack span:hover {
        transform: translateY(-3px);
        background: #2563eb;
        color: #fff;
        border-color: #2563eb;
        box-shadow: var(--shadow-button-hover);
    }

    .awards-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5vh 2vw;
        list-style: none;
    }

    .award-item {
        font-size: 0.95rem;
        color: #333;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid transparent;
        padding-bottom: 2px;
        transition: all 0.2s;
        line-height: 1.4;
    }

    .award-item.has-cert {
        cursor: pointer;
    }

    .award-item.has-cert:hover {
        color: #2563eb;
        border-bottom-color: #2563eb;
        transform: translateX(3px);
    }

    .award-item.has-cert::after {
        content: '↗';
        color: #ccc;
        font-size: 0.8rem;
        margin-left: 8px;
        flex-shrink: 0;
    }

    .edu-list {
        display: flex;
        flex-direction: column;
        gap: 1.5vh;
    }

    .edu-item {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        border-left: 4px solid #2563eb;
        padding-left: 12px;
        transition: transform 0.2s;
    }

    .edu-item:hover {
        transform: translateX(5px);
    }

    .edu-school {
        font-weight: bold;
        font-size: 1.05rem;
    }

    .edu-major {
        font-size: 0.9rem;
        color: #666;
        margin-top: 2px;
    }

    .edu-time {
        font-size: 0.9rem;
        color: #999;
    }

    .right-panel {
        flex: 0 0 40%;
        height: calc(100vh - 80px);
        position: sticky;
        top: 80px;
        display: flex;
        align-items: flex-end;
        justify-content: flex-end;
    }

    .portrait {
        width: auto;
        height: 90vh;
        max-width: 100%;
        object-fit: contain;
        object-position: bottom;
        transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .portrait:hover {
        transform: scale(1.02);
    }

    #gallery {
        display: none;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .layout {
        animation: fadeIn 0.8s ease-out;
    }

    .left-panel > * {
        opacity: 0;
        animation: fadeInUp 0.6s ease-out forwards;
    }

    .left-panel > *:nth-child(1) { animation-delay: 0.1s; }
    .left-panel > *:nth-child(2) { animation-delay: 0.2s; }
    .left-panel > *:nth-child(3) { animation-delay: 0.3s; }
    .left-panel > *:nth-child(4) { animation-delay: 0.4s; }
    .left-panel > *:nth-child(5) { animation-delay: 0.5s; }

    .right-panel {
        opacity: 0;
        animation: fadeInUp 0.6s ease-out 0.3s forwards;
    }

    @media (max-width: 900px) {
        .layout {
            flex-direction: column-reverse;
            display: flex;
        }
        .left-panel {
            flex: none;
            width: 100%;
            padding: 4vh 6vw 10vh 6vw;
        }
        .header {
            text-align: center;
        }
        .right-panel {
            flex: none;
            width: 100%;
            height: 60vh;
            position: relative;
            top: 0;
            justify-content: center;
        }
        .portrait {
            height: 100%;
        }
        .awards-grid {
            grid-template-columns: 1fr;
        }
        .edu-item {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>
