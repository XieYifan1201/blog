---
import Layout from '../layouts/Layout.astro';

const awards = [
    {
        title: '入围第48届世界技能大赛移动应用开发中国集训队',
        tag: '入围集训队',
    },
    {
        title: '第48届世界技能大赛中国集训队集中性考核暨测试赛移动应用开发赛项第六名',
        tag: '第六名',
    },
    {
        title: '中华人民共和国第三届职业技能大赛移动应用开发赛项第六名',
        tag: '第六名',
    },
    {
        title: '2024至2025学年国家奖学金',
        tag: '国家奖学金',
    },
    {
        title: '计算机程序设计员职业技能等级高级技师',
        tag: '高级技师',
    },
    {
        title: '2023至2024学年国家励志奖学金',
        tag: '国家励志奖学金',
    },
    {
        title: '一带一路暨金砖国家技能发展与技术创新大赛——Web赛项三等奖',
        tag: '三等奖',
    },
    {
        title: '江西省第二届职业技能大赛移动应用开发赛项第一名',
        tag: '第一名',
    },
    {
        title: '江西省第一届职业技能大赛网站设计与开发赛项第二名',
        tag: '第二名',
    },
    {
        title: '九江市第三届职业技能大赛移动应用开发赛项第一名',
        tag: '第一名',
    },
];

const certificates = [
    {
        image: '/certificates/gjjxj.jpeg',
    },
    {
        image: '/certificates/gjlzjxj.jpeg',
    },
    {
        image: '/certificates/zhrmghgdsjzyjnds.jpeg',
    },
    {
        image: '/certificates/ydyljjzgjjnfzyjscxds.jpeg',
    },
    {
        image: '/certificates/jxsdejzyjnds.jpeg',
    },
    {
        image: '/certificates/jxsdyjzyjnds.jpeg',
    },
    {
        image: '/certificates/jjsdsjchjjzyjnds.jpeg',
    },
];
---

<Layout>
<div id="container">
    <div class="spotlight"></div>

    <nav>
        <a href="/" class="logo"><img src="/favicon.jpeg" alt="Logo" class="logo-img" /></a>
        <div class="nav-links">
            <a href="/">首页</a>
            <a href="/posts">文章</a>
            <a href="/about" class="active">关于</a>
        </div>
    </nav>

    <main>
        <section id="about-hero">
            <div class="avatar-wrapper">
                <img src="/favicon.jpeg" alt="Avatar" class="avatar-img" />
            </div>
            <h1>关于 <span class="gradient-text">我</span></h1>
            <p class="subtitle">
                一名热爱技术与设计的创作者，专注于程序开发与用户体验设计。<br />
                相信好的代码如同好的文字——简洁、优雅、有力量。
            </p>
        </section>

        <section id="details">
            <div class="detail-card">
                <div class="detail-icon">💡</div>
                <h3>技术探索者</h3>
                <p>持续学习各类技术栈，从 Vue 到 Flutter，追求最佳的开发体验与性能表现。</p>
            </div>
            <div class="detail-card">
                <div class="detail-icon">🎨</div>
                <h3>设计践行者</h3>
                <p>关注 UI/UX 设计，善于将设计思维融入开发流程，让产品既好用又好看。</p>
            </div>
            <div class="detail-card">
                <div class="detail-icon">📝</div>
                <h3>知识分享者</h3>
                <p>通过博客记录学习心得与项目经验，在分享中加深理解，在交流中共同成长。</p>
            </div>
        </section>

        <section id="awards">
            <h2 class="section-title">荣誉</h2>
            <div class="awards-grid">
                {awards.map((award) => (
                <div class="award-card">
                    <div class="award-info">
                        <h3>{award.title}</h3>
                        <span class="award-tag">{award.tag}</span>
                    </div>
                </div>
                ))}
            </div>
        </section>

        {certificates.length > 0 && (
        <section id="certificates">
            <h2 class="section-title">证书</h2>
            <div class="cert-masonry">
                {certificates.map((cert) => (
                <div class="cert-card" onclick="openLightbox(this.querySelector('img').src)">
                    <img src={cert.image} alt={cert.title} loading="lazy" />
                    {cert.title && <div class="cert-name">{cert.title}</div>}
                </div>
                ))}
            </div>
        </section>
        )}

        <div id="lightbox" onclick="closeLightbox()">
            <button id="lightbox-close" onclick="event.stopPropagation(); closeLightbox()">✕</button>
            <img id="lightbox-img" src="" alt="" onclick="event.stopPropagation()" />
        </div>

        <section id="contact">
            <a href="/" class="button primary">返回首页</a>
        </section>
    </main>
</div>

<script is:inline>
function openLightbox(src) {
    const lb = document.getElementById('lightbox');
    const img = document.getElementById('lightbox-img');
    img.src = src;
    lb.classList.add('active');
    document.body.style.overflow = 'hidden';
}
function closeLightbox() {
    const lb = document.getElementById('lightbox');
    lb.classList.remove('active');
    document.body.style.overflow = '';
}
document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
});
</script>

<style>
    :root {
        --accent: #7c3aed;
        --accent-gradient: linear-gradient(45deg, #7c3aed, #ff1fb1);
        --bg-color: #0a0a0a;
        --text-main: #ffffff;
        --text-muted: #a1a1aa;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background-color: var(--bg-color);
        color: var(--text-main);
        font-family: 'Inter', 'SF Pro Display', system-ui, sans-serif;
        overflow-x: hidden;
    }

    #container {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        position: relative;
    }

    .spotlight {
        position: fixed;
        top: -20%;
        left: 50%;
        transform: translateX(-50%);
        width: 80vw;
        height: 60vh;
        background: radial-gradient(circle, rgba(124, 58, 237, 0.15) 0%, rgba(0,0,0,0) 70%);
        z-index: -1;
        pointer-events: none;
    }

    nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 2rem 10%;
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(10, 10, 10, 0.8);
        backdrop-filter: blur(12px);
    }

    .logo {
        text-decoration: none;
        display: flex;
        align-items: center;
    }

    .logo-img {
        height: 36px;
        width: 36px;
        object-fit: cover;
        border-radius: 50%;
    }

    .nav-links a {
        color: var(--text-muted);
        text-decoration: none;
        margin-left: 2rem;
        font-size: 0.9rem;
        transition: color 0.3s;
    }

    .nav-links a:hover,
    .nav-links a.active {
        color: var(--text-main);
    }

    main {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2rem 1rem 4rem;
    }

    #about-hero {
        text-align: center;
        max-width: 700px;
        animation: fadeInUp 0.8s ease-out;
        margin-bottom: 4rem;
    }

    .avatar-wrapper {
        margin-bottom: 2rem;
    }

    .avatar-img {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        object-fit: cover;
        box-shadow: 0 0 40px rgba(124, 58, 237, 0.3);
    }

    h1 {
        font-size: clamp(2.5rem, 8vw, 4.5rem);
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 1.5rem;
    }

    .gradient-text {
        background: var(--accent-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .subtitle {
        font-size: 1.15rem;
        color: var(--text-muted);
        line-height: 1.8;
    }

    #details {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        max-width: 900px;
        width: 100%;
        margin-bottom: 5rem;
        animation: fadeInUp 0.8s ease-out 0.15s both;
    }

    .detail-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        padding: 2rem 1.5rem;
        text-align: center;
        transition: all 0.3s;
        backdrop-filter: blur(10px);
    }

    .detail-card:hover {
        border-color: var(--accent);
        background: rgba(255, 255, 255, 0.05);
        transform: translateY(-4px);
    }

    .detail-icon {
        font-size: 2.5rem;
        margin-bottom: 1rem;
    }

    .detail-card h3 {
        font-size: 1.05rem;
        margin-bottom: 0.6rem;
    }

    .detail-card p {
        font-size: 0.85rem;
        color: var(--text-muted);
        line-height: 1.6;
    }

    #awards {
        width: 100%;
        max-width: 900px;
        margin-bottom: 4rem;
        animation: fadeInUp 0.8s ease-out 0.3s both;
    }

    .section-title {
        text-align: center;
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 2.5rem;
    }

    .awards-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
    }

    .award-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        padding: 1.8rem;
        transition: all 0.3s;
        backdrop-filter: blur(10px);
    }

    .award-card:hover {
        border-color: var(--accent);
        background: rgba(255, 255, 255, 0.05);
        transform: translateY(-4px);
    }

    .award-info h3 {
        font-size: 1rem;
        margin-bottom: 0.4rem;
    }

    .award-tag {
        display: inline-block;
        background: rgba(124, 58, 237, 0.1);
        border: 1px solid rgba(124, 58, 237, 0.3);
        color: #a78bfa;
        padding: 2px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
        margin-bottom: 0.5rem;
    }

    .award-info p {
        font-size: 0.85rem;
        color: var(--text-muted);
        line-height: 1.5;
    }

    #certificates {
        width: 100%;
        max-width: 900px;
        margin-bottom: 4rem;
        animation: fadeInUp 0.8s ease-out 0.4s both;
    }

    .cert-masonry {
        columns: 2;
        column-gap: 1.2rem;
    }

    .cert-card {
        break-inside: avoid;
        margin-bottom: 1.2rem;
        border-radius: 16px;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.06);
        transition: all 0.35s;
        cursor: pointer;
    }

    .cert-card:hover {
        border-color: rgba(124, 58, 237, 0.4);
        transform: translateY(-3px);
        box-shadow: 0 12px 40px rgba(124, 58, 237, 0.1);
    }

    .cert-card img {
        width: 100%;
        height: auto;
        display: block;
    }

    .cert-name {
        padding: 0.7rem 1rem;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text-muted);
    }

    #lightbox {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: rgba(0, 0, 0, 0.9);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.3s, visibility 0.3s;
        cursor: zoom-out;
    }

    #lightbox.active {
        opacity: 1;
        visibility: visible;
    }

    #lightbox img {
        max-width: 92vw;
        max-height: 92vh;
        object-fit: contain;
        border-radius: 8px;
        box-shadow: 0 0 60px rgba(0, 0, 0, 0.5);
    }

    #lightbox-close {
        position: absolute;
        top: 1.5rem;
        right: 1.5rem;
        width: 40px;
        height: 40px;
        border: none;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.15);
        color: #fff;
        font-size: 1.2rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s;
        z-index: 10000;
    }

    #lightbox-close:hover {
        background: rgba(255, 255, 255, 0.3);
    }

    #contact {
        display: flex;
        gap: 1rem;
        justify-content: center;
        animation: fadeInUp 0.8s ease-out 0.45s both;
    }

    .button {
        padding: 0.8rem 2rem;
        border-radius: 12px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s;
    }

    .button.primary {
        background: var(--text-main);
        color: var(--bg-color);
    }

    .button.primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(255, 255, 255, 0.1);
    }

    .button.secondary {
        border: 1px solid #333;
        color: var(--text-main);
    }

    .button.secondary:hover {
        background: rgba(255,255,255,0.05);
        border-color: #555;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 768px) {
        nav { padding: 1.5rem 5%; }
        h1 { font-size: 2.5rem; }
        #details { grid-template-columns: 1fr; }
        .awards-grid { grid-template-columns: 1fr; }
        .cert-masonry { columns: 1; }
        #contact { flex-direction: column; width: 100%; }
        .button { width: 100%; text-align: center; }
    }
</style>
