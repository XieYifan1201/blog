---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
---

<Layout title="图片格式转换 - XIE YIFAN" description="在线图片格式转换工具，支持多种图片格式">
    <Nav active="工具" />

    <main>
        <div class="back-link-wrapper">
            <a href="/tools" class="back-link">← 返回工具列表</a>
        </div>

        <section id="tool-hero">
            <h1>图片格式转换</h1>
            <p class="subtitle">上传单张或多张图片，离线转换为其他格式</p>
        </section>

        <div class="tool-container">
            <div class="upload-area" id="upload-area">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="17 8 12 3 7 8"></polyline>
                    <line x1="12" y1="3" x2="12" y2="15"></line>
                </svg>
                <p>点击或拖拽图片到此处</p>
                <span class="upload-hint">支持 PNG、JPG、WEBP、BMP、GIF、AVIF、ICO、TIFF、SVG，可多选</span>
                <input type="file" id="file-input" accept="image/*" multiple hidden />
            </div>

            <div class="convert-options" id="convert-options" style="display: none;">
                <div class="file-list" id="file-list"></div>

                <div class="format-selector">
                    <label for="target-format">目标格式：</label>
                    <select id="target-format">
                        <option value="image/png">PNG</option>
                        <option value="image/jpeg">JPG</option>
                        <option value="image/webp">WEBP</option>
                        <option value="image/bmp">BMP</option>
                        <option value="image/gif">GIF</option>
                        <option value="image/avif">AVIF</option>
                        <option value="image/x-icon">ICO</option>
                        <option value="image/tiff">TIFF</option>
                        <option value="image/svg+xml">SVG</option>
                    </select>
                </div>

                <div class="quality-selector" id="quality-selector">
                    <label for="quality">质量：<span id="quality-value">95%</span></label>
                    <input type="range" id="quality" min="10" max="100" value="95" oninput="updateQuality()" />
                </div>

                <button class="convert-btn" id="convert-btn" onclick="convertImages()">转换并下载</button>
            </div>
        </div>
    </main>
</Layout>

<script is:inline>
let uploadedFiles = [];

const uploadArea = document.getElementById('upload-area');
const fileInput = document.getElementById('file-input');
const convertOptions = document.getElementById('convert-options');
const fileList = document.getElementById('file-list');

uploadArea.addEventListener('click', () => fileInput.click());

uploadArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadArea.classList.add('drag-over');
});

uploadArea.addEventListener('dragleave', () => {
    uploadArea.classList.remove('drag-over');
});

uploadArea.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadArea.classList.remove('drag-over');
    handleFiles(e.dataTransfer.files);
});

fileInput.addEventListener('change', (e) => {
    handleFiles(e.target.files);
});

function handleFiles(files) {
    for (const file of files) {
        if (file.type.startsWith('image/')) {
            uploadedFiles.push(file);
        }
    }
    updateFileList();
}

function updateFileList() {
    if (uploadedFiles.length === 0) {
        convertOptions.style.display = 'none';
        return;
    }

    convertOptions.style.display = 'block';
    fileList.innerHTML = uploadedFiles.map((file, i) => `
        <div class="file-item">
            <span class="file-name">${file.name}</span>
            <span class="file-size">${formatSize(file.size)}</span>
            <button class="remove-btn" onclick="removeFile(${i})">✕</button>
        </div>
    `).join('');
}

function formatSize(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
}

function removeFile(index) {
    uploadedFiles.splice(index, 1);
    updateFileList();
}

function updateQuality() {
    document.getElementById('quality-value').textContent = document.getElementById('quality').value + '%';
}

async function convertImages() {
    const format = document.getElementById('target-format').value;
    const quality = parseInt(document.getElementById('quality').value) / 100;
    const ext = getExtension(format);

    for (const file of uploadedFiles) {
        const img = new Image();
        img.src = URL.createObjectURL(file);
        await new Promise((resolve) => { img.onload = resolve; });

        const canvas = document.createElement('canvas');
        canvas.width = img.width;
        canvas.height = img.height;
        const ctx = canvas.getContext('2d');

        if (format === 'image/jpeg' || format === 'image/bmp') {
            ctx.fillStyle = '#FFFFFF';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
        }

        ctx.drawImage(img, 0, 0);

        if (format === 'image/svg+xml') {
            const svgContent = `<svg xmlns="http://www.w3.org/2000/svg" width="${img.width}" height="${img.height}">
                <image href="${img.src}" width="${img.width}" height="${img.height}"/>
            </svg>`;
            const blob = new Blob([svgContent], { type: 'image/svg+xml' });
            downloadBlob(blob, file.name.replace(/\.[^.]+$/, '') + '.' + ext);
        } else if (format === 'image/x-icon') {
            canvas.width = Math.min(img.width, 256);
            canvas.height = Math.min(img.height, 256);
            ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
            canvas.toBlob((blob) => {
                downloadBlob(blob, file.name.replace(/\.[^.]+$/, '') + '.ico');
            }, 'image/png', quality);
        } else {
            canvas.toBlob((blob) => {
                downloadBlob(blob, file.name.replace(/\.[^.]+$/, '') + '.' + ext);
            }, format, quality);
        }

        URL.revokeObjectURL(img.src);
    }
}

function getExtension(format) {
    const map = {
        'image/png': 'png',
        'image/jpeg': 'jpg',
        'image/webp': 'webp',
        'image/bmp': 'bmp',
        'image/gif': 'gif',
        'image/avif': 'avif',
        'image/x-icon': 'ico',
        'image/tiff': 'tiff',
        'image/svg+xml': 'svg',
    };
    return map[format] || 'png';
}

function downloadBlob(blob, filename) {
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    a.click();
    URL.revokeObjectURL(url);
}
</script>

<style>
    main {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2rem 0 4rem;
        max-width: var(--site-narrow-width);
        margin: 0 auto;
        width: calc(100% - var(--site-page-gutter-total));
    }

    .back-link-wrapper {
        width: 100%;
        padding-bottom: 1.5rem;
        animation: fadeInUp 0.8s ease-out;
    }

    .back-link {
        color: #2563eb;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 600;
        display: inline-block;
        transition: color 0.3s;
    }

    .back-link:hover {
        color: #1d4ed8;
    }

    #tool-hero {
        text-align: center;
        margin-bottom: 3rem;
        animation: fadeInUp 0.8s ease-out 0.1s both;
    }

    #tool-hero h1 {
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 900;
        letter-spacing: -1px;
        margin-bottom: 0.8rem;
        color: #000;
    }

    .subtitle {
        font-size: 1.1rem;
        color: #666;
    }

    .tool-container {
        width: 100%;
        animation: fadeInUp 0.8s ease-out 0.2s both;
    }

    .upload-area {
        background: #f9fafb;
        border: 2px dashed #d1d5db;
        border-radius: 16px;
        padding: 3rem 2rem;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s;
        box-shadow: var(--shadow-card);
    }

    .upload-area:hover,
    .upload-area.drag-over {
        border-color: #2563eb;
        background: #f0f4ff;
        box-shadow: var(--shadow-card-hover);
    }

    .upload-area svg {
        color: #999;
        margin-bottom: 1rem;
    }

    .upload-area p {
        font-size: 1.1rem;
        margin-bottom: 0.5rem;
        color: #333;
    }

    .upload-hint {
        font-size: 0.85rem;
        color: #999;
    }

    .convert-options {
        margin-top: 2rem;
    }

    .file-list {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
        margin-bottom: 1.5rem;
    }

    .file-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        background: #fff;
        border: 1px solid #eee;
        border-radius: 12px;
        padding: 1rem 1.2rem;
        box-shadow: var(--shadow-card);
    }

    .file-name {
        flex: 1;
        font-size: 0.95rem;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        color: #333;
    }

    .file-size {
        font-size: 0.85rem;
        color: #999;
    }

    .remove-btn {
        background: none;
        border: none;
        color: #999;
        cursor: pointer;
        font-size: 1rem;
        padding: 0.2rem;
        transition: color 0.2s;
    }

    .remove-btn:hover {
        color: #ef4444;
    }

    .format-selector {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .format-selector label {
        font-size: 0.95rem;
        color: #666;
    }

    .format-selector select {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 0.6rem 1rem;
        color: #000;
        font-size: 0.95rem;
        cursor: pointer;
    }

    .format-selector select:focus {
        outline: none;
        border-color: #2563eb;
    }

    .quality-selector {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .quality-selector label {
        font-size: 0.95rem;
        color: #666;
        min-width: 100px;
    }

    .quality-selector input[type="range"] {
        flex: 1;
        height: 6px;
        -webkit-appearance: none;
        background: #e5e7eb;
        border-radius: 3px;
        outline: none;
    }

    .quality-selector input[type="range"]::-webkit-slider-thumb {
        -webkit-appearance: none;
        width: 18px;
        height: 18px;
        background: #2563eb;
        border-radius: 50%;
        cursor: pointer;
    }

    .convert-btn {
        width: 100%;
        padding: 1rem;
        background: #2563eb;
        border: none;
        border-radius: 12px;
        color: #fff;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
        box-shadow: var(--shadow-button);
    }

    .convert-btn:hover {
        background: #1d4ed8;
        transform: translateY(-2px);
        box-shadow: var(--shadow-button-hover);
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 900px) {
        main { padding: 1.5rem 0 3rem; }
        #tool-hero h1 { font-size: 2rem; }
        .upload-area { padding: 2rem 1.5rem; }
    }
</style>
