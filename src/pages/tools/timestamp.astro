---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
---

<Layout title="时间戳转换 - XIE YIFAN" description="Unix 时间戳与日期互相转换">
    <Nav active="工具" />

    <main>
        <div class="back-link-wrapper">
            <a href="/tools" class="back-link">← 返回工具列表</a>
        </div>

        <section id="tool-hero">
            <h1>时间戳转换</h1>
            <p class="subtitle">Unix 时间戳与日期时间互相转换</p>
        </section>

        <div class="tool-container">
            <div class="current-time-card">
                <span class="label">当前时间</span>
                <div class="time-display" id="current-time"></div>
                <div class="timestamp-display" id="current-timestamp"></div>
            </div>

            <div class="converter-section">
                <h3>时间戳 → 日期时间</h3>
                <div class="input-row">
                    <input type="text" id="timestamp-input" placeholder="输入时间戳（秒或毫秒）" />
                    <button class="convert-btn" onclick="timestampToDate()">转换</button>
                </div>
                <div class="result-display" id="date-result"></div>
            </div>

            <div class="converter-section">
                <h3>日期时间 → 时间戳</h3>
                <div class="input-row">
                    <input type="text" id="date-input" placeholder="输入日期时间，如 2025-02-17 14:30:00" />
                    <button class="convert-btn" onclick="dateToTimestamp()">转换</button>
                </div>
                <div class="result-display" id="timestamp-result"></div>
            </div>
        </div>
    </main>
</Layout>

<script is:inline>
function updateCurrentTime() {
    const now = new Date();
    const timeStr = now.toLocaleString('zh-CN', {
        year: 'numeric', month: '2-digit', day: '2-digit',
        hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false
    });
    const ts = Math.floor(now.getTime() / 1000);

    const timeEl = document.getElementById('current-time');
    timeEl.textContent = timeStr;
    timeEl.onclick = () => copyValue(timeEl, timeStr);
    timeEl.classList.add('copyable');

    const tsEl = document.getElementById('current-timestamp');
    tsEl.textContent = ts;
    tsEl.onclick = () => copyValue(tsEl, ts.toString());
    tsEl.classList.add('copyable');
}

updateCurrentTime();
setInterval(updateCurrentTime, 1000);

function timestampToDate() {
    const input = document.getElementById('timestamp-input').value.trim();
    const result = document.getElementById('date-result');

    if (!input) { result.textContent = ''; return; }

    let ts = parseInt(input);
    if (isNaN(ts)) { result.textContent = '请输入有效的时间戳'; return; }

    if (input.length > 10) ts = ts;
    else ts = ts * 1000;

    const date = new Date(ts);
    if (isNaN(date.getTime())) { result.textContent = '无效的时间戳'; return; }

    const localTime = date.toLocaleString('zh-CN', { hour12: false });
    const utcTime = date.toUTCString();
    const isoTime = date.toISOString();

    result.innerHTML = `
        <div class="result-item">
            <span class="result-label">本地时间：</span>
            <span class="result-value copyable" onclick="copyValue(this, '${localTime}')">${localTime}</span>
        </div>
        <div class="result-item">
            <span class="result-label">UTC 时间：</span>
            <span class="result-value copyable" onclick="copyValue(this, '${utcTime}')">${utcTime}</span>
        </div>
        <div class="result-item">
            <span class="result-label">ISO 格式：</span>
            <span class="result-value copyable" onclick="copyValue(this, '${isoTime}')">${isoTime}</span>
        </div>
    `;
}

function dateToTimestamp() {
    const input = document.getElementById('date-input').value.trim();
    const result = document.getElementById('timestamp-result');

    if (!input) { result.textContent = ''; return; }

    const date = new Date(input);
    if (isNaN(date.getTime())) { result.textContent = '无效的日期时间格式'; return; }

    const seconds = Math.floor(date.getTime() / 1000);
    const milliseconds = date.getTime();

    result.innerHTML = `
        <div class="result-item">
            <span class="result-label">秒：</span>
            <span class="result-value copyable" onclick="copyValue(this, '${seconds}')">${seconds}</span>
        </div>
        <div class="result-item">
            <span class="result-label">毫秒：</span>
            <span class="result-value copyable" onclick="copyValue(this, '${milliseconds}')">${milliseconds}</span>
        </div>
    `;
}

function copyValue(el, text) {
    navigator.clipboard.writeText(text);
    const original = el.textContent;
    el.textContent = '✓ 已复制';
    el.classList.add('copied');
    setTimeout(() => {
        el.textContent = original;
        el.classList.remove('copied');
    }, 1200);
}
</script>

<style>
    main {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2rem 0 4rem;
        max-width: var(--site-narrow-width);
        margin: 0 auto;
        width: calc(100% - var(--site-page-gutter-total));
    }

    .back-link-wrapper {
        width: 100%;
        padding-bottom: 1.5rem;
        animation: fadeInUp 0.8s ease-out;
    }

    .back-link {
        color: #2563eb;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 600;
        display: inline-block;
        transition: color 0.3s;
    }

    .back-link:hover {
        color: #1d4ed8;
    }

    #tool-hero {
        text-align: center;
        margin-bottom: 3rem;
        animation: fadeInUp 0.8s ease-out 0.1s both;
    }

    #tool-hero h1 {
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 900;
        letter-spacing: -1px;
        margin-bottom: 0.8rem;
        color: #000;
    }

    .subtitle {
        font-size: 1.1rem;
        color: #666;
    }

    .tool-container {
        width: 100%;
        animation: fadeInUp 0.8s ease-out 0.2s both;
    }

    .current-time-card {
        background: #fff;
        border: 1px solid #eee;
        border-radius: 16px;
        padding: 2rem;
        text-align: center;
        margin-bottom: 2rem;
        box-shadow: var(--shadow-card);
    }

    .current-time-card .label {
        font-size: 0.85rem;
        color: #666;
        display: block;
        margin-bottom: 0.8rem;
    }

    .time-display {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
        color: #000;
    }

    .timestamp-display {
        font-size: 1.1rem;
        color: #2563eb;
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
    }

    .time-display.copyable,
    .timestamp-display.copyable {
        cursor: pointer;
        padding: 0.3rem 0.6rem;
        border-radius: 6px;
        transition: all 0.2s;
    }

    .time-display.copyable:hover,
    .timestamp-display.copyable:hover {
        background: #f0f4ff;
    }

    .time-display.copyable.copied,
    .timestamp-display.copyable.copied {
        background: #dcfce7;
        color: #16a34a;
    }

    .converter-section {
        background: #fff;
        border: 1px solid #eee;
        border-radius: 16px;
        padding: 2rem;
        margin-bottom: 1.5rem;
        box-shadow: var(--shadow-card);
    }

    .converter-section h3 {
        font-size: 1.1rem;
        margin-bottom: 1.2rem;
        color: #666;
    }

    .input-row {
        display: flex;
        gap: 0.8rem;
    }

    .input-row input {
        flex: 1;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 0.8rem 1rem;
        color: #000;
        font-size: 0.95rem;
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
    }

    .input-row input:focus {
        outline: none;
        border-color: #2563eb;
    }

    .convert-btn {
        padding: 0.8rem 1.5rem;
        background: #2563eb;
        border: none;
        border-radius: 10px;
        color: #fff;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
        white-space: nowrap;
        box-shadow: var(--shadow-button);
    }

    .convert-btn:hover {
        background: #1d4ed8;
        transform: translateY(-2px);
        box-shadow: var(--shadow-button-hover);
    }

    .result-display {
        margin-top: 1.2rem;
        padding: 1rem;
        background: #f9fafb;
        border-radius: 10px;
        min-height: 3rem;
    }

    .result-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.4rem 0;
        font-size: 0.95rem;
    }

    .result-label {
        color: #666;
    }

    .result-value {
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
        flex: 1;
        text-align: right;
        margin-right: 0.5rem;
    }

    .result-value.copyable {
        cursor: pointer;
        padding: 0.3rem 0.6rem;
        border-radius: 6px;
        transition: all 0.2s;
        user-select: all;
    }

    .result-value.copyable:hover {
        background: #f0f4ff;
        color: #2563eb;
    }

    .result-value.copyable.copied {
        background: #dcfce7;
        color: #16a34a;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 900px) {
        main { padding: 1.5rem 0 3rem; }
        #tool-hero h1 { font-size: 2rem; }
        .input-row { flex-direction: column; }
        .time-display { font-size: 1.5rem; }
    }
</style>
