---
import Layout from '../layouts/Layout.astro';

const tools = [
    {
        name: '图片格式转换',
        description: '上传单/多张图片，离线转换为 PNG、JPG、WEBP、BMP、GIF、AVIF、ICO、TIFF、SVG 等格式',
        url: '/tools/image-converter',
        icon: '🖼️',
    },
    {
        name: '视频格式转换',
        description: '上传单/多个视频，离线转换为 MP4、WEBM、AVI、MOV、MKV、GIF 等格式，或提取音频',
        url: '/tools/video-converter',
        icon: '🎬',
    },
    {
        name: 'Base64 编解码',
        description: '将文本或图片编码为 Base64，或将 Base64 解码为原文/图片',
        url: '/tools/base64',
        icon: '🔐',
    },
    {
        name: '时间戳转换',
        description: 'Unix 时间戳与日期时间互相转换，支持一键复制结果',
        url: '/tools/timestamp',
        icon: '⏰',
    },
    {
        name: '颜色转换',
        description: 'HEX、RGB、HSL 颜色格式互相转换',
        url: '/tools/color-converter',
        icon: '🎨',
    },
    {
        name: 'Markdown 阅读器',
        description: '上传 Markdown 文件，使用文章同款样式即时预览',
        url: '/tools/markdown-reader',
        icon: '📝',
    },
];
---

<Layout title="工具 - XIE YIFAN" description="实用的在线工具集合">
<div id="container">
    <div class="spotlight"></div>

    <nav>
        <a href="/" class="logo"><img src="/favicon.jpeg" alt="Logo" class="logo-img" /></a>
        <div class="nav-links">
            <a href="/">首页</a>
            <a href="/posts">文章</a>
            <a href="/projects">项目</a>
            <a href="/tools" class="active">工具</a>
            <a href="/about">关于</a>
        </div>
    </nav>

    <main>
        <section id="tools-hero">
            <h1>实用<span class="gradient-text">工具</span></h1>
            <p class="subtitle">简单、高效的在线工具集合</p>
        </section>

        <div class="tools-grid">
            {tools.map((tool) => (
                <a href={tool.url} class="tool-card">
                    <div class="tool-icon">{tool.icon}</div>
                    <h3>{tool.name}</h3>
                    <p>{tool.description}</p>
                    <span class="use-tool">使用工具 →</span>
                </a>
            ))}
        </div>

        <footer class="page-footer">
            <a href="/" class="button primary">返回首页</a>
        </footer>
    </main>
</div>
</Layout>

<style>
    :root {
        --accent: #7c3aed;
        --accent-gradient: linear-gradient(45deg, #7c3aed, #ff1fb1);
        --bg-color: #0a0a0a;
        --text-main: #ffffff;
        --text-muted: #a1a1aa;
    }

    * {
        box-sizing: border-box;
    }

    body {
        color: var(--text-main);
        font-family: 'Inter', 'SF Pro Display', system-ui, sans-serif;
        overflow-x: hidden;
    }

    #container {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        position: relative;
        z-index: 1;
    }

    .spotlight {
        position: fixed;
        top: -30%;
        left: 50%;
        transform: translateX(-50%);
        width: 150vw;
        height: 150vh;
        background: radial-gradient(ellipse at center, rgba(124, 58, 237, 0.12) 0%, rgba(124, 58, 237, 0.03) 50%, rgba(0, 0, 0, 0) 80%);
        z-index: -1;
        pointer-events: none;
    }

    nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 2rem 10%;
        animation: fadeInUp 0.8s ease-out;
    }

    .logo {
        display: flex;
        align-items: center;
        text-decoration: none;
    }

    .logo-img {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
    }

    .nav-links a {
        color: var(--text-muted);
        text-decoration: none;
        margin-left: 2rem;
        font-size: 0.9rem;
        font-weight: 500;
        transition: color 0.3s;
    }

    .nav-links a:hover,
    .nav-links a.active {
        color: var(--text-main);
    }

    main {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2rem 1rem 4rem;
        max-width: 1000px;
        margin: 0 auto;
        width: 100%;
    }

    #tools-hero {
        text-align: center;
        margin-bottom: 4rem;
        animation: fadeInUp 0.8s ease-out;
    }

    #tools-hero h1 {
        font-size: clamp(2.5rem, 6vw, 3.5rem);
        font-weight: 800;
        margin-bottom: 1rem;
    }

    .gradient-text {
        background: var(--accent-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .subtitle {
        font-size: 1.1rem;
        color: var(--text-muted);
    }

    .tools-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        width: 100%;
        animation: fadeInUp 0.8s ease-out 0.2s both;
    }

    .tool-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        padding: 2rem;
        text-decoration: none;
        color: var(--text-main);
        transition: all 0.35s;
        display: flex;
        flex-direction: column;
        text-align: center;
    }

    .tool-card:hover {
        border-color: rgba(124, 58, 237, 0.4);
        transform: translateY(-4px);
        box-shadow: 0 12px 40px rgba(124, 58, 237, 0.1);
    }

    .tool-icon {
        font-size: 2.5rem;
        margin-bottom: 1rem;
    }

    .tool-card h3 {
        font-size: 1.2rem;
        font-weight: 700;
        margin: 0 0 0.8rem 0;
    }

    .tool-card p {
        color: var(--text-muted);
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 1.2rem;
        flex: 1;
    }

    .use-tool {
        color: var(--accent);
        font-size: 0.9rem;
        font-weight: 600;
        transition: color 0.3s;
    }

    .tool-card:hover .use-tool {
        color: #a78bfa;
    }

    .page-footer {
        margin-top: 4rem;
        text-align: center;
        animation: fadeInUp 0.8s ease-out 0.4s both;
    }

    .button {
        padding: 0.8rem 2rem;
        border-radius: 12px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s;
    }

    .button.primary {
        background: var(--text-main);
        color: var(--bg-color);
    }

    .button.primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(255, 255, 255, 0.1);
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 768px) {
        nav { padding: 1.5rem 5%; }
        #tools-hero h1 { font-size: 2rem; }
        .tools-grid { grid-template-columns: 1fr; }
    }
</style>
