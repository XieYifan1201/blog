---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';

const tools = [
    {
        name: '图片格式转换',
        description: '上传单/多张图片，离线转换为 PNG、JPG、WEBP、BMP、GIF、AVIF、ICO、TIFF、SVG 等格式',
        url: '/tools/image-converter',
        icon: '🖼️',
    },
    {
        name: '视频格式转换',
        description: '上传单/多个视频，离线转换为 MP4、WEBM、AVI、MOV、MKV、GIF 等格式，或提取音频',
        url: '/tools/video-converter',
        icon: '🎬',
    },
    {
        name: 'Base64 编解码',
        description: '将文本或图片编码为 Base64，或将 Base64 解码为原文/图片',
        url: '/tools/base64',
        icon: '🔐',
    },
    {
        name: '时间戳转换',
        description: 'Unix 时间戳与日期时间互相转换，支持一键复制结果',
        url: '/tools/timestamp',
        icon: '⏰',
    },
    {
        name: '颜色转换',
        description: 'HEX、RGB、HSL 颜色格式互相转换',
        url: '/tools/color-converter',
        icon: '🎨',
    },
    {
        name: 'Markdown 阅读器',
        description: '上传 Markdown 文件，使用文章同款样式即时预览',
        url: '/tools/markdown-reader',
        icon: '📝',
    },
];
---

<Layout title="工具 - XIE YIFAN" description="实用的在线工具集合">
    <Nav active="工具" />

    <main>
        <section id="tools-hero">
            <h1>实用工具</h1>
            <p class="subtitle">简单、高效的在线工具集合</p>
        </section>

        <div class="tools-grid">
            {tools.map((tool) => (
                <a href={tool.url} class="tool-card">
                    <div class="tool-icon">{tool.icon}</div>
                    <h3>{tool.name}</h3>
                    <p>{tool.description}</p>
                    <span class="use-tool">使用工具 →</span>
                </a>
            ))}
        </div>
    </main>
</Layout>

<style>
    main {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2rem 0 4rem;
        max-width: var(--site-content-width);
        margin: 0 auto;
        width: calc(100% - var(--site-page-gutter-total));
    }

    #tools-hero {
        text-align: center;
        margin-bottom: 3rem;
        animation: fadeInUp 0.8s ease-out;
    }

    h1 {
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 900;
        letter-spacing: -2px;
        line-height: 1.1;
        margin-bottom: 0.8rem;
        color: #000;
    }

    .subtitle {
        font-size: 1.1rem;
        color: #666;
    }

    .tools-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        width: 100%;
        animation: fadeInUp 0.8s ease-out 0.2s both;
    }

    .tool-card {
        background: #fff;
        border: 1px solid #eee;
        border-radius: 16px;
        padding: 2rem;
        text-decoration: none;
        color: #000;
        transition: all 0.35s;
        display: flex;
        flex-direction: column;
        text-align: center;
        box-shadow: var(--shadow-card);
    }

    .tool-card:hover {
        border-color: #2563eb;
        transform: translateY(-4px);
        box-shadow: var(--shadow-card-hover);
    }

    .tool-icon {
        font-size: 2.5rem;
        margin-bottom: 1rem;
    }

    .tool-card h3 {
        font-size: 1.2rem;
        font-weight: 700;
        margin: 0 0 0.8rem 0;
        color: #000;
    }

    .tool-card p {
        color: #666;
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 1.2rem;
        flex: 1;
    }

    .use-tool {
        color: #2563eb;
        font-size: 0.9rem;
        font-weight: 600;
        transition: color 0.3s;
    }

    .tool-card:hover .use-tool {
        color: #1d4ed8;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 900px) {
        main { padding: 2rem 0 4rem; }
        h1 { font-size: 2rem; }
        .tools-grid { grid-template-columns: 1fr; }
    }
</style>
