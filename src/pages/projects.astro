---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';

const projects = [
    {
        name: 'GanJunMi-Server',
        description: '基于 Spring Boot 2.7 的培训管理后端服务，提供微信 OAuth 登录、JWT 认证、证书管理、发票管理等 RESTful API。',
        url: 'https://github.com/XieYifan1201/GanJunMi-Server',
        tags: ['Spring Boot', 'MyBatis', 'Java', 'JWT'],
    },
    {
        name: 'GanJunMi-App',
        description: '基于 uni-app 的培训管理移动端应用，支持微信授权登录、在线报名、证书扫码查询，一套代码多端运行。',
        url: 'https://github.com/XieYifan1201/GanJunMi-App',
        tags: ['uni-app', 'Vue 3', '微信小程序', '跨端开发'],
    },
    {
        name: 'GanJunMi-Admin',
        description: '基于 Vue 2 的培训机构一站式后台管理系统，涵盖培训管理、学员管理、证书生成打印等全流程功能。',
        url: 'https://github.com/XieYifan1201/GanJunMi-Admin',
        tags: ['Vue 2', 'Element UI', 'Canvas', 'ECharts'],
    },
    {
        name: 'SailChat',
        description: '基于 Flutter 开发的即时通讯应用，支持消息收发、联系人管理等功能，注重用户体验与界面设计。',
        url: 'https://github.com/XieYifan1201/SailChat',
        tags: ['Flutter', 'Dart', 'IM'],
    },
    {
        name: 'SailChat-Server',
        description: 'SailChat 的后端服务，基于 Spring Boot 构建，提供 RESTful API 与 WebSocket 支持。',
        url: 'https://github.com/XieYifan1201/SailChat-Server',
        tags: ['Spring Boot', 'Java', 'WebSocket'],
    },
];
---

<Layout title="项目 - XIE YIFAN" description="XIE YIFAN 的开源项目与作品">
    <Nav active="项目" />

    <main>
        <section id="projects-hero">
            <h1>我的项目</h1>
            <p class="subtitle">探索、创造与分享</p>
        </section>

        <div class="projects-grid">
            {projects.reverse().map((project) => (
                <a href={project.url} target="_blank" rel="noopener" class="project-card">
                    <h3>{project.name}</h3>
                    <p>{project.description}</p>
                    <div class="project-tags">
                        {project.tags.map((tag) => (
                            <span class="tag">{tag}</span>
                        ))}
                    </div>
                    <span class="view-project">在 GitHub 查看 →</span>
                </a>
            ))}
        </div>
    </main>
</Layout>

<style>
    main {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2rem 0 4rem;
        max-width: var(--site-content-width);
        margin: 0 auto;
        width: calc(100% - var(--site-page-gutter-total));
    }

    #projects-hero {
        text-align: center;
        margin-bottom: 3rem;
        animation: fadeInUp 0.8s ease-out;
    }

    h1 {
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 900;
        letter-spacing: -2px;
        line-height: 1.1;
        margin-bottom: 0.8rem;
        color: #000;
    }

    .subtitle {
        font-size: 1.1rem;
        color: #666;
    }

    .projects-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        width: 100%;
        animation: fadeInUp 0.8s ease-out 0.2s both;
    }

    .project-card {
        background: #fff;
        border: 1px solid #eee;
        border-radius: 16px;
        padding: 2rem;
        text-decoration: none;
        color: #000;
        transition: all 0.35s;
        display: flex;
        flex-direction: column;
        box-shadow: var(--shadow-card);
    }

    .project-card:hover {
        border-color: #2563eb;
        transform: translateY(-4px);
        box-shadow: var(--shadow-card-hover);
    }

    .project-card h3 {
        font-size: 1.2rem;
        font-weight: 700;
        margin: 0 0 1rem 0;
        color: #000;
    }

    .project-card p {
        color: #666;
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 1.2rem;
        flex: 1;
    }

    .project-tags {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-bottom: 1.2rem;
    }

    .tag {
        padding: 0.3rem 0.8rem;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 600;
        background: #f0f4ff;
        border: 1px solid #dbeafe;
        color: #2563eb;
    }

    .view-project {
        color: #2563eb;
        font-size: 0.9rem;
        font-weight: 600;
        transition: color 0.3s;
    }

    .project-card:hover .view-project {
        color: #1d4ed8;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 900px) {
        main { padding: 2rem 0 4rem; }
        h1 { font-size: 2rem; }
        .projects-grid { grid-template-columns: 1fr; }
    }
</style>
