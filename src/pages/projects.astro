---
import Layout from '../layouts/Layout.astro';

const projects = [
    {
        name: 'GanJunMi-Server',
        description: '基于 Spring Boot 2.7 的培训管理后端服务，提供微信 OAuth 登录、JWT 认证、证书管理、发票管理等 RESTful API。',
        url: 'https://github.com/XieYifan1201/GanJunMi-Server',
        tags: ['Spring Boot', 'MyBatis', 'Java', 'JWT'],
    },
    {
        name: 'GanJunMi-App',
        description: '基于 uni-app 的培训管理移动端应用，支持微信授权登录、在线报名、证书扫码查询，一套代码多端运行。',
        url: 'https://github.com/XieYifan1201/GanJunMi-App',
        tags: ['uni-app', 'Vue 3', '微信小程序', '跨端开发'],
    },
    {
        name: 'GanJunMi-Admin',
        description: '基于 Vue 2 的培训机构一站式后台管理系统，涵盖培训管理、学员管理、证书生成打印等全流程功能。',
        url: 'https://github.com/XieYifan1201/GanJunMi-Admin',
        tags: ['Vue 2', 'Element UI', 'Canvas', 'ECharts'],
    },
    {
        name: 'SailChat',
        description: '基于 Flutter 开发的即时通讯应用，支持消息收发、联系人管理等功能，注重用户体验与界面设计。',
        url: 'https://github.com/XieYifan1201/SailChat',
        tags: ['Flutter', 'Dart', 'IM'],
    },
    {
        name: 'SailChat-Server',
        description: 'SailChat 的后端服务，基于 Spring Boot 构建，提供 RESTful API 与 WebSocket 支持。',
        url: 'https://github.com/XieYifan1201/SailChat-Server',
        tags: ['Spring Boot', 'Java', 'WebSocket'],
    },
];
---

<Layout title="项目 - XIE YIFAN" description="XIE YIFAN 的开源项目与作品">
<div id="container">
    <div class="spotlight"></div>

    <nav>
        <a href="/" class="logo"><img src="/favicon.jpeg" alt="Logo" class="logo-img" /></a>
        <div class="nav-links">
            <a href="/">首页</a>
            <a href="/posts">文章</a>
            <a href="/projects" class="active">项目</a>
            <a href="/about">关于</a>
        </div>
    </nav>

    <main>
        <section id="projects-hero">
            <h1>我的<span class="gradient-text">项目</span></h1>
            <p class="subtitle">探索、创造与分享</p>
        </section>

        <div class="projects-grid">
            {projects.reverse().map((project) => (
                <a href={project.url} target="_blank" rel="noopener" class="project-card">
                    <div class="project-header">
                        <svg class="github-icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 2.28-.315.66 0 1.32.09 1.98.27.66-.18 1.32-.27 1.98-.27 1.275 0 2.28.315 2.28.315.66 1.65.24 2.88.12 3.18.765.84 1.23 1.92 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
                        </svg>
                        <h3>{project.name}</h3>
                    </div>
                    <p>{project.description}</p>
                    <div class="project-tags">
                        {project.tags.map((tag) => (
                            <span class="tag">{tag}</span>
                        ))}
                    </div>
                    <span class="view-project">查看项目 →</span>
                </a>
            ))}
        </div>

        <footer class="page-footer">
            <a href="/" class="button primary">返回首页</a>
        </footer>
    </main>
</div>
</Layout>

<style>
    :root {
        --accent: #7c3aed;
        --accent-gradient: linear-gradient(45deg, #7c3aed, #ff1fb1);
        --bg-color: #0a0a0a;
        --text-main: #ffffff;
        --text-muted: #a1a1aa;
    }

    * {
        box-sizing: border-box;
    }

    body {
        color: var(--text-main);
        font-family: 'Inter', 'SF Pro Display', system-ui, sans-serif;
        overflow-x: hidden;
    }

    #container {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        position: relative;
        z-index: 1;
    }

    .spotlight {
        position: fixed;
        top: -30%;
        left: 50%;
        transform: translateX(-50%);
        width: 150vw;
        height: 150vh;
        background: radial-gradient(ellipse at center, rgba(124, 58, 237, 0.12) 0%, rgba(124, 58, 237, 0.03) 50%, rgba(0, 0, 0, 0) 80%);
        z-index: -1;
        pointer-events: none;
    }

    nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 2rem 10%;
        animation: fadeInUp 0.8s ease-out;
    }

    .logo {
        display: flex;
        align-items: center;
        text-decoration: none;
    }

    .logo-img {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
    }

    .nav-links a {
        color: var(--text-muted);
        text-decoration: none;
        margin-left: 2rem;
        font-size: 0.9rem;
        font-weight: 500;
        transition: color 0.3s;
    }

    .nav-links a:hover,
    .nav-links a.active {
        color: var(--text-main);
    }

    main {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2rem 1rem 4rem;
        max-width: 1000px;
        margin: 0 auto;
        width: 100%;
    }

    #projects-hero {
        text-align: center;
        margin-bottom: 4rem;
        animation: fadeInUp 0.8s ease-out;
    }

    #projects-hero h1 {
        font-size: clamp(2.5rem, 6vw, 3.5rem);
        font-weight: 800;
        margin-bottom: 1rem;
    }

    .gradient-text {
        background: var(--accent-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .subtitle {
        font-size: 1.1rem;
        color: var(--text-muted);
    }

    .projects-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        width: 100%;
        animation: fadeInUp 0.8s ease-out 0.2s both;
    }

    .project-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        padding: 2rem;
        text-decoration: none;
        color: var(--text-main);
        transition: all 0.35s;
        display: flex;
        flex-direction: column;
    }

    .project-card:hover {
        border-color: rgba(124, 58, 237, 0.4);
        transform: translateY(-4px);
        box-shadow: 0 12px 40px rgba(124, 58, 237, 0.1);
    }

    .project-header {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        margin-bottom: 1rem;
    }

    .github-icon {
        color: var(--text-main);
        flex-shrink: 0;
    }

    .project-header h3 {
        font-size: 1.2rem;
        font-weight: 700;
        margin: 0;
    }

    .project-card p {
        color: var(--text-muted);
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 1.2rem;
        flex: 1;
    }

    .project-tags {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-bottom: 1.2rem;
    }

    .tag {
        padding: 0.3rem 0.8rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        background: rgba(124, 58, 237, 0.1);
        border: 1px solid rgba(124, 58, 237, 0.3);
        color: #a78bfa;
    }

    .view-project {
        color: var(--accent);
        font-size: 0.9rem;
        font-weight: 600;
        transition: color 0.3s;
    }

    .project-card:hover .view-project {
        color: #a78bfa;
    }

    .page-footer {
        margin-top: 4rem;
        text-align: center;
        animation: fadeInUp 0.8s ease-out 0.4s both;
    }

    .button {
        padding: 0.8rem 2rem;
        border-radius: 12px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s;
    }

    .button.primary {
        background: var(--text-main);
        color: var(--bg-color);
    }

    .button.primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(255, 255, 255, 0.1);
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 768px) {
        nav { padding: 1.5rem 5%; }
        #projects-hero h1 { font-size: 2rem; }
        .projects-grid { grid-template-columns: 1fr; }
    }
</style>
